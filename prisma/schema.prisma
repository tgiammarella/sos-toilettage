generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Role {
  ADMIN
  SALON
  GROOMER
}

enum SubscriptionPlan {
  NONE
  BASIC
  PRO
}

enum SubscriptionStatus {
  ACTIVE
  INACTIVE
  PAST_DUE
  CANCELED
}

enum ShiftStatus {
  DRAFT
  PUBLISHED
  FILLED
  ARCHIVED
}

enum JobStatus {
  DRAFT
  PUBLISHED
  FILLED
  ARCHIVED
}

enum ApplicationStatus {
  APPLIED
  ACCEPTED
  REJECTED
  WITHDRAWN
}

enum PostType {
  SHIFT
  JOB
}

enum PayType {
  HOURLY
  FLAT
}

enum CreditType {
  CREDIT
  DEBIT
}

enum TrainingType {
  SCHOOL
  TRAINING
}

enum EngagementStatus {
  CONFIRMED
  COMPLETED
  CANCELLED
}

enum EmploymentType {
  FULL_TIME
  PART_TIME
  CONTRACT
}

// ─── Auth Models (NextAuth v5 / Auth.js) ──────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  role          Role      @default(GROOMER)
  isBanned      Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts       Account[]
  salonProfile   SalonProfile?
  groomerProfile GroomerProfile?
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Domain Models ────────────────────────────────────────────────────────────

model SalonProfile {
  id                 String             @id @default(cuid())
  userId             String             @unique
  name               String
  address            String
  city               String
  region             String
  postalCode         String
  phone              String?
  website            String?
  description        String?
  stripeCustomerId        String?            @unique
  subscriptionPlan        SubscriptionPlan   @default(NONE)
  subscriptionStatus      SubscriptionStatus @default(INACTIVE)
  subscriptionId          String?
  creditsAvailable        Int                @default(0)
  creditsMonthlyAllowance Int                @default(0)
  createdAt               DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  shiftPosts      ShiftPost[]
  jobPosts        JobPost[]
  creditLedger    CreditLedger[]
  engagements     Engagement[]
  reviewsGiven    Review[]       @relation("ReviewerSalon")
  reviewsReceived Review[]       @relation("SubjectSalon")
}

model GroomerProfile {
  id              String   @id @default(cuid())
  userId          String   @unique
  fullName        String
  photoUrl        String?
  city            String
  region          String
  yearsExperience Int      @default(0)
  // SQLite: stored as JSON string. Use JSON.parse/JSON.stringify in app code.
  // Switch back to String[] when migrating to PostgreSQL.
  specializations String   @default("[]")
  certifications  String   @default("[]")
  portfolioUrls   String   @default("[]")
  cvFileUrl       String?
  bio             String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  applications    Application[]
  engagements     Engagement[]
  reviewsGiven    Review[]       @relation("ReviewerGroomer")
  reviewsReceived Review[]       @relation("SubjectGroomer")
}

model ShiftPost {
  id                      String      @id @default(cuid())
  salonId                 String
  date                    DateTime
  startTime               String
  address                 String
  city                    String
  region                  String
  postalCode              String
  lat                     Float?
  lng                     Float?
  numberOfAppointments    Int
  payType                 PayType
  payRateCents            Int
  requiredExperienceYears Int         @default(0)
  // SQLite: JSON string. Switch to String[] for PostgreSQL.
  criteriaTags            String      @default("[]")
  equipmentProvided       Boolean     @default(false)
  notes                   String?
  isUrgent                Boolean     @default(false)
  urgentPurchasedAt       DateTime?
  status                  ShiftStatus @default(DRAFT)
  publishedAt             DateTime?
  filledAt                DateTime?
  createdAt               DateTime    @default(now())
  updatedAt               DateTime    @updatedAt

  salon         SalonProfile   @relation(fields: [salonId], references: [id], onDelete: Cascade)
  applications  Application[]
  engagement    Engagement?
  creditLedger  CreditLedger[]

  @@index([date, city, region, status])
}

model JobPost {
  id             String         @id @default(cuid())
  salonId        String
  title          String
  employmentType EmploymentType
  city           String
  region         String
  description    String
  payInfo        String?
  requirements   String?
  status         JobStatus      @default(DRAFT)
  publishedAt    DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  salon        SalonProfile  @relation(fields: [salonId], references: [id], onDelete: Cascade)
  applications Application[]
  engagement   Engagement?

  @@index([city, region, status])
}

model Application {
  id                String            @id @default(cuid())
  postType          PostType
  shiftPostId       String?
  jobPostId         String?
  salonId           String
  groomerId         String
  status            ApplicationStatus @default(APPLIED)
  shortlisted       Boolean           @default(false)
  message           String?
  availabilityDates String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  shiftPost ShiftPost?     @relation(fields: [shiftPostId], references: [id])
  jobPost   JobPost?       @relation(fields: [jobPostId], references: [id])
  groomer   GroomerProfile @relation(fields: [groomerId], references: [id])

  @@index([shiftPostId, status])
  @@index([jobPostId, status])
  @@index([groomerId])
  @@index([salonId, groomerId])
}

model Engagement {
  id          String           @id @default(cuid())
  shiftPostId String?          @unique
  jobPostId   String?          @unique
  salonId     String
  groomerId   String
  startsAt    DateTime
  status      EngagementStatus @default(CONFIRMED)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  shiftPost ShiftPost?     @relation(fields: [shiftPostId], references: [id])
  jobPost   JobPost?       @relation(fields: [jobPostId], references: [id])
  salon     SalonProfile   @relation(fields: [salonId], references: [id])
  groomer   GroomerProfile @relation(fields: [groomerId], references: [id])
  reviews   Review[]
}

model Review {
  id             String   @id @default(cuid())
  engagementId   String
  // Reviewer
  reviewerUserId String
  reviewerRole   Role
  reviewerSalonId   String?
  reviewerGroomerId String?
  // Subject
  subjectUserId  String
  subjectRole    Role
  subjectSalonId    String?
  subjectGroomerId  String?
  // Content
  rating         Int
  text           String?
  createdAt      DateTime @default(now())

  engagement        Engagement      @relation(fields: [engagementId], references: [id])
  reviewerSalon     SalonProfile?   @relation("ReviewerSalon",  fields: [reviewerSalonId],   references: [id])
  subjectSalon      SalonProfile?   @relation("SubjectSalon",   fields: [subjectSalonId],    references: [id])
  reviewerGroomer   GroomerProfile? @relation("ReviewerGroomer", fields: [reviewerGroomerId], references: [id])
  subjectGroomer    GroomerProfile? @relation("SubjectGroomer",  fields: [subjectGroomerId],  references: [id])

  @@unique([engagementId, reviewerUserId])
  @@index([subjectUserId])
}

// ─── Billing ──────────────────────────────────────────────────────────────────

model CreditLedger {
  id        String     @id @default(cuid())
  salonId   String
  type      CreditType
  amount    Int
  reason    String
  shiftId   String?
  // Stripe hook placeholder — populated when Stripe webhooks are implemented.
  stripeEventId String? @unique
  createdAt DateTime   @default(now())

  salon SalonProfile @relation(fields: [salonId], references: [id])
  shift ShiftPost?   @relation(fields: [shiftId], references: [id])

  @@index([salonId, createdAt])
}

// ─── Directory ────────────────────────────────────────────────────────────────

model TrainingListing {
  id          String       @id @default(cuid())
  type        TrainingType
  name        String
  city        String
  region      String
  websiteUrl  String?
  phone       String?
  email       String?
  description String?
  // SQLite: JSON string. Switch to String[] for PostgreSQL.
  tags        String       @default("[]")
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}
