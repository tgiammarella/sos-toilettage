generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Role {
  ADMIN
  SALON
  GROOMER
}

enum SubscriptionPlan {
  NONE
  BASIC
  PRO
}

enum SubscriptionStatus {
  ACTIVE
  INACTIVE
  PAST_DUE
  CANCELED
}

enum ShiftStatus {
  DRAFT
  PUBLISHED
  FILLED
  COMPLETED
  ARCHIVED
}

enum JobStatus {
  DRAFT
  PUBLISHED
  FILLED
  EXPIRED
  ARCHIVED
}

enum ApplicationStatus {
  APPLIED
  ACCEPTED
  REJECTED
  WITHDRAWN
}

enum PostType {
  SHIFT
  JOB
}

enum PayType {
  HOURLY
  FLAT
}

enum CreditType {
  CREDIT
  DEBIT
}

enum TrainingType {
  SCHOOL
  COURSE
  WORKSHOP
  CERTIFICATION
}

enum EngagementStatus {
  CONFIRMED
  COMPLETED
  CANCELLED
}

enum InviteStatus {
  PENDING
  ACCEPTED
  DECLINED
}

enum EmploymentType {
  FULL_TIME
  PART_TIME
  CONTRACT
}

enum ModerationActionType {
  BAN
  UNBAN
  SUSPEND
  REACTIVATE
  BLOCK_EMAIL
  UNBLOCK_EMAIL
}

// ─── Auth Models (NextAuth v5 / Auth.js) ──────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  role          Role      @default(GROOMER)

  // ─── Email verification ───
  verifyToken       String?   @unique
  verifyTokenExpiry DateTime?

  // ─── Moderation fields ───
  isBanned                Boolean   @default(false)
  bannedAt                DateTime?
  bannedReason            String?
  bannedNotes             String?
  bannedByUserId          String?

  isSuspended             Boolean   @default(false)
  suspendedAt             DateTime?
  suspensionEndsAt        DateTime?
  suspendedReason         String?
  suspendedNotes          String?
  suspendedByUserId       String?

  moderationEmailBlocked  Boolean   @default(false)

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts             Account[]
  salonProfile         SalonProfile?
  groomerProfile       GroomerProfile?
  moderationActions    AdminModerationAction[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Domain Models ────────────────────────────────────────────────────────────

model SalonProfile {
  id                 String             @id @default(cuid())
  userId             String             @unique
  name               String
  address            String
  city               String
  region             String
  postalCode         String
  phone              String?
  website            String?
  description        String?
  stripeCustomerId        String?            @unique
  subscriptionPlan        SubscriptionPlan   @default(NONE)
  subscriptionStatus      SubscriptionStatus @default(INACTIVE)
  subscriptionId          String?
  creditsAvailable        Int                @default(0)
  creditsMonthlyAllowance Int                @default(0)
  // Internal billing (no Stripe required). Maps to PRICING_TIERS keys: ESSENTIEL | SALON | RESEAU | CHAINE | NONE
  planKey                 String             @default("NONE")
  nextRenewalAt           DateTime?
  createdAt               DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  shiftPosts      ShiftPost[]
  jobPosts        JobPost[]
  creditLedger    CreditLedger[]
  engagements     Engagement[]
  reviewsGiven    Review[]       @relation("ReviewerSalon")
  reviewsReceived Review[]       @relation("SubjectSalon")
  couponUses      CouponUse[]
  openSlots       OpenSlot[]
}

model GroomerProfile {
  id              String   @id @default(cuid())
  userId          String   @unique
  fullName        String
  photoUrl        String?
  city            String
  region          String
  yearsExperience Int      @default(0)
  // SQLite: stored as JSON string. Use JSON.parse/JSON.stringify in app code.
  // Switch back to String[] when migrating to PostgreSQL.
  specializations String   @default("[]")
  certifications  String   @default("[]")
  portfolioUrls   String   @default("[]")
  cvFileUrl         String?
  bio               String?
  availableToday    Boolean  @default(false)
  reliabilityScore  Float    @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  applications    Application[]
  engagements     Engagement[]
  shiftInvites    ShiftInvite[]
  reviewsGiven    Review[]       @relation("ReviewerGroomer")
  reviewsReceived Review[]       @relation("SubjectGroomer")
}

model ShiftPost {
  id                      String      @id @default(cuid())
  salonId                 String
  date                    DateTime
  startTime               String
  address                 String
  city                    String
  region                  String
  postalCode              String
  lat                     Float?
  lng                     Float?
  numberOfAppointments    Int
  payType                 PayType
  payRateCents            Int
  requiredExperienceYears Int         @default(0)
  // SQLite: JSON string. Switch to String[] for PostgreSQL.
  criteriaTags            String      @default("[]")
  equipmentProvided       Boolean     @default(false)
  notes                   String?
  isUrgent                Boolean     @default(false)
  urgentActivatedAt       DateTime?
  status                  ShiftStatus @default(DRAFT)
  publishedAt             DateTime?
  filledAt                DateTime?
  completedAt             DateTime?
  createdAt               DateTime    @default(now())
  updatedAt               DateTime    @updatedAt

  salon         SalonProfile   @relation(fields: [salonId], references: [id], onDelete: Cascade)
  applications  Application[]
  engagement    Engagement?
  creditLedger  CreditLedger[]
  invites       ShiftInvite[]

  @@index([date, city, region, status])
}

model JobPost {
  id             String         @id @default(cuid())
  salonId        String
  title          String
  employmentType EmploymentType
  city           String
  region         String
  description    String
  payInfo        String?
  requirements   String?
  status         JobStatus      @default(DRAFT)
  publishedAt    DateTime?
  expiresAt      DateTime?
  isFeatured     Boolean        @default(false)
  paidAt         DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  salon        SalonProfile  @relation(fields: [salonId], references: [id], onDelete: Cascade)
  applications Application[]
  engagement   Engagement?

  @@index([city, region, status])
}

model Application {
  id                String            @id @default(cuid())
  postType          PostType
  shiftPostId       String?
  jobPostId         String?
  salonId           String
  groomerId         String
  status            ApplicationStatus @default(APPLIED)
  shortlisted       Boolean           @default(false)
  message           String?
  availabilityDates String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  shiftPost ShiftPost?     @relation(fields: [shiftPostId], references: [id], onDelete: Cascade)
  jobPost   JobPost?       @relation(fields: [jobPostId], references: [id], onDelete: Cascade)
  groomer   GroomerProfile @relation(fields: [groomerId], references: [id], onDelete: Cascade)

  @@unique([shiftPostId, groomerId])
  @@unique([jobPostId, groomerId])
  @@index([shiftPostId, status])
  @@index([jobPostId, status])
  @@index([groomerId])
  @@index([salonId, groomerId])
}

model Engagement {
  id          String           @id @default(cuid())
  shiftPostId String?          @unique
  jobPostId   String?          @unique
  salonId     String
  groomerId   String
  startsAt    DateTime
  status      EngagementStatus @default(CONFIRMED)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  shiftPost ShiftPost?     @relation(fields: [shiftPostId], references: [id], onDelete: SetNull)
  jobPost   JobPost?       @relation(fields: [jobPostId], references: [id], onDelete: SetNull)
  salon     SalonProfile   @relation(fields: [salonId], references: [id], onDelete: Cascade)
  groomer   GroomerProfile @relation(fields: [groomerId], references: [id], onDelete: Cascade)
  reviews   Review[]
}

model Review {
  id             String   @id @default(cuid())
  engagementId   String
  // Reviewer
  reviewerUserId String
  reviewerRole   Role
  reviewerSalonId   String?
  reviewerGroomerId String?
  // Subject
  subjectUserId  String
  subjectRole    Role
  subjectSalonId    String?
  subjectGroomerId  String?
  // Content
  rating         Int
  text           String?
  createdAt      DateTime @default(now())

  engagement        Engagement      @relation(fields: [engagementId], references: [id])
  reviewerSalon     SalonProfile?   @relation("ReviewerSalon",  fields: [reviewerSalonId],   references: [id])
  subjectSalon      SalonProfile?   @relation("SubjectSalon",   fields: [subjectSalonId],    references: [id])
  reviewerGroomer   GroomerProfile? @relation("ReviewerGroomer", fields: [reviewerGroomerId], references: [id])
  subjectGroomer    GroomerProfile? @relation("SubjectGroomer",  fields: [subjectGroomerId],  references: [id])

  @@unique([engagementId, reviewerUserId])
  @@index([subjectUserId])
}

// ─── Invites ──────────────────────────────────────────────────────────────────

model ShiftInvite {
  id        String       @id @default(cuid())
  shiftId   String
  groomerId String
  status    InviteStatus @default(PENDING)
  sentAt    DateTime     @default(now())

  shift   ShiftPost      @relation(fields: [shiftId], references: [id], onDelete: Cascade)
  groomer GroomerProfile @relation(fields: [groomerId], references: [id], onDelete: Cascade)

  @@unique([shiftId, groomerId])
  @@index([groomerId])
}

// ─── Billing ──────────────────────────────────────────────────────────────────

model CreditLedger {
  id        String     @id @default(cuid())
  salonId   String
  type      CreditType
  amount    Int
  reason    String
  shiftId   String?
  // Stripe hook placeholder — populated when Stripe webhooks are implemented.
  stripeEventId String? @unique
  createdAt DateTime   @default(now())

  salon SalonProfile @relation(fields: [salonId], references: [id], onDelete: Cascade)
  shift ShiftPost?   @relation(fields: [shiftId], references: [id], onDelete: SetNull)

  @@index([salonId, createdAt])
}

// ─── Coupons ──────────────────────────────────────────────────────────────────

model Coupon {
  id        String    @id @default(cuid())
  code      String    @unique
  // "CREDITS" = credits only; "PLAN" = plan change only; "BOTH" = credits + plan
  type      String
  credits   Int       @default(0)
  planKey   String?   // target plan: ESSENTIEL | SALON | RESEAU | CHAINE
  maxUses   Int       @default(1)
  usedCount Int       @default(0)
  expiresAt DateTime?
  createdAt DateTime  @default(now())

  uses CouponUse[]
}

model CouponUse {
  id        String       @id @default(cuid())
  couponId  String
  salonId   String
  createdAt DateTime     @default(now())

  coupon Coupon       @relation(fields: [couponId], references: [id])
  salon  SalonProfile @relation(fields: [salonId], references: [id])

  @@unique([couponId, salonId])
}

// ─── Moderation ──────────────────────────────────────────────────────────────

model AdminModerationAction {
  id             String               @id @default(cuid())
  userId         String
  adminUserId    String
  actionType     ModerationActionType
  reason         String?
  notes          String?
  createdAt      DateTime             @default(now())
  effectiveUntil DateTime?

  user User @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
}

// ─── Open Slots (Créneaux Disponibles) ───────────────────────────────────────

enum OpenSlotStatus {
  ACTIVE
  FILLED
  CANCELLED
  EXPIRED
}

enum OpenSlotService {
  BAIN_COUPE
  BAIN_SEULEMENT
  COUPE_SEULEMENT
  TOILETTAGE_COMPLET
  AUTRE
}

enum DogSize {
  TRES_PETIT
  PETIT
  MOYEN
  GRAND
  TRES_GRAND
}

model OpenSlot {
  id          String          @id @default(cuid())
  salonId     String
  date        DateTime
  durationMin Int
  serviceType OpenSlotService
  dogSize     DogSize?
  price       Float?
  notes       String?
  status      OpenSlotStatus  @default(ACTIVE)
  expiresAt   DateTime
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  salon SalonProfile @relation(fields: [salonId], references: [id], onDelete: Cascade)

  @@index([status, expiresAt])
  @@index([salonId, status])
}

// ─── Directory ────────────────────────────────────────────────────────────────

model TrainingListing {
  id          String       @id @default(cuid())
  type        TrainingType
  name        String
  city        String
  province    String       @default("")
  region      String
  websiteUrl  String?
  logoUrl     String?
  phone       String?
  email       String?
  description String?
  // SQLite: JSON string. Switch to String[] for PostgreSQL.
  tags        String       @default("[]")
  isFeatured  Boolean      @default(false)
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}
